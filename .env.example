# ---- Server ----
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*

# ---- Database (PostgreSQL / Neon) ----
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ---- Auth (JWT) ----
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# ---- LLM (Google Gemini, free tier) ----
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ---- External integration (Resend email) ----
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=Hintro Reminders <onboarding@resend.dev>
# Demo helper: route ALL reminder emails to one verified inbox (Resend free tier only
# delivers to the account owner unless a domain is verified). Leave blank in production.
REMINDER_TO_OVERRIDE=put_email_associated_with_render_account

# ---- Reminder scheduler ----
REMINDER_CRON=*/15 * * * *
REMINDER_CRON_ENABLED=true
REMINDER_DEDUPE_HOURS=24
# Shared secret required in the `x-cron-secret` header on GET /api/internal/cron/reminders
CRON_SECRET=replace-with-a-random-cron-secret

# ---- Evaluation endpoint metadata ----
CANDIDATE_NAME=Your Name
CANDIDATE_EMAIL=you@example.com
REPOSITORY_URL=https://github.com/you/meeting-intelligence-service
DEPLOYED_URL=https://your-app.onrender.com


